# Copy this file to .streamlit/secrets.toml and fill in values IF you switch to
# a weather provider that requires an API key. The default providers
# (Open-Meteo + Zippopotam.us) need NO key, so this is optional.
#
# .streamlit/secrets.toml is gitignored - never commit real keys.

# WEATHER_API_KEY = "your-key-here"
